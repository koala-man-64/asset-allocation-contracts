          "maxLength": 128,
          "minLength": 1,
          "title": "Assignmentid",
          "type": "string"
        },
        "createdAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Createdat"
        },
        "effectiveFrom": {
          "format": "date",
          "title": "Effectivefrom",
          "type": "string"
        },
        "effectiveTo": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effectiveto"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
