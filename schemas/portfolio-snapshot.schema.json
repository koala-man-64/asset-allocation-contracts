        "targetWeight": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Targetweight",
          "type": "number"
        },
        "turnover": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Turnover"
        }
      },
      "required": [
        "asOf",
        "sleeveId",
        "strategyName",
        "strategyVersion",
        "targetWeight",
        "actualWeight",
        "marketValue"
      ],
      "title": "StrategySliceAttribution",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "accountId": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Accountid",
      "type": "string"
