{
  "$defs": {
    "FreshnessStatus": {
      "additionalProperties": false,
      "properties": {
        "asOf": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asof"
        },
        "checkedAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkedat"
        },
        "domain": {
          "enum": [
            "valuation",
            "positions",
            "risk",
            "attribution",
            "ledger",
            "alerts"
          ],
          "title": "Domain",
          "type": "string"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string"
        },
        "state": {
          "enum": [
            "fresh",
            "stale",
            "error",
            "missing"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "required": [
        "domain",
        "state"
      ],
      "title": "FreshnessStatus",
      "type": "object"
    },
    "PortfolioAssignment": {
