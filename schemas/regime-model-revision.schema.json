{
  "$defs": {
    "RegimeMetricRule": {
      "additionalProperties": false,
      "properties": {
        "comparison": {
          "enum": [
            "gte",
            "lte",
            "between",
            "bool_true"
          ],
          "title": "Comparison",
          "type": "string"
        },
        "description": {
          "default": "",
          "maxLength": 512,
          "title": "Description",
          "type": "string"
        },
        "lower": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower"
        },
        "metric": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "upper": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper"
        }
      },
      "required": [
        "metric",
        "comparison"
      ],
      "title": "RegimeMetricRule",
      "type": "object"
    },
    "RegimeModelConfig": {
      "additionalProperties": false,
      "properties": {
        "activationThreshold": {
          "default": 0.6,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Activationthreshold",
          "type": "number"
        },
        "haltVixStreakDays": {
          "default": 2,
          "minimum": 1,
          "title": "Haltvixstreakdays",
          "type": "integer"
        },
        "haltVixThreshold": {
          "default": 32.0,
          "title": "Haltvixthreshold",
          "type": "number"
        },
        "signalConfigs": {
          "additionalProperties": {
            "$ref": "#/$defs/RegimeSignalConfig"
          },
          "propertyNames": {
            "enum": [
              "trending_up",
              "trending_down",
              "mean_reverting",
              "low_volatility",
              "high_volatility",
              "liquidity_stress",
              "macro_alignment",
              "unclassified"
            ]
          },
          "title": "Signalconfigs",
          "type": "object"
        }
      },
      "title": "RegimeModelConfig",
      "type": "object"
    },
    "RegimeSignalConfig": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Displayname",
          "type": "string"
        },
        "requiredMetrics": {
          "items": {
            "type": "string"
          },
          "title": "Requiredmetrics",
          "type": "array"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/RegimeMetricRule"
          },
          "title": "Rules",
          "type": "array"
        }
      },
      "required": [
        "displayName"
      ],
      "title": "RegimeSignalConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "activated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Activated At"
    },
    "activated_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Activated By"
    },
    "config": {
      "$ref": "#/$defs/RegimeModelConfig"
    },
    "config_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Config Hash"
    },
    "created_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "published_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Published At"
    },
    "status": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Status"
    },
    "version": {
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "name",
    "version",
    "config"
  ],
  "title": "RegimeModelRevision",
  "type": "object"
}
