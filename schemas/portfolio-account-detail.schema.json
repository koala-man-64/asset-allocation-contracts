{
  "$defs": {
    "PortfolioAccount": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Accountid",
          "type": "string"
        },
        "accountingDepth": {
          "const": "position_level",
          "default": "position_level",
          "title": "Accountingdepth",
          "type": "string"
        },
        "activePortfolioName": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activeportfolioname"
        },
        "activePortfolioVersion": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activeportfolioversion"
        },
        "activeRevision": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activerevision"
        },
        "baseCurrency": {
          "default": "USD",
          "maxLength": 3,
          "minLength": 3,
          "title": "Basecurrency",
          "type": "string"
        },
        "benchmarkSymbol": {
          "anyOf": [
            {
              "maxLength": 32,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Benchmarksymbol"
        },
        "cadenceMode": {
          "const": "strategy_native",
          "default": "strategy_native",
          "title": "Cadencemode",
          "type": "string"
        },
        "createdAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Createdat"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "inceptionDate": {
          "format": "date",
          "title": "Inceptiondate",
          "type": "string"
        },
        "lastMaterializedAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lastmaterializedat"
        },
        "latestRevision": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latestrevision"
        },
        "mandate": {
          "default": "",
          "title": "Mandate",
          "type": "string"
        },
        "mode": {
          "const": "internal_model_managed",
          "default": "internal_model_managed",
          "title": "Mode",
          "type": "string"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "openAlertCount": {
          "default": 0,
          "minimum": 0,
          "title": "Openalertcount",
          "type": "integer"
        },
        "status": {
          "default": "draft",
          "enum": [
            "draft",
            "active",
            "archived"
          ],
          "title": "Status",
          "type": "string"
        },
        "updatedAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updatedat"
        }
      },
      "required": [
        "accountId",
        "name",
        "inceptionDate"
      ],
      "title": "PortfolioAccount",
      "type": "object"
    },
    "PortfolioAccountRevision": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Accountid",
          "type": "string"
        },
        "accountingDepth": {
          "const": "position_level",
          "default": "position_level",
          "title": "Accountingdepth",
          "type": "string"
        },
        "baseCurrency": {
          "default": "USD",
          "maxLength": 3,
          "minLength": 3,
          "title": "Basecurrency",
          "type": "string"
        },
        "benchmarkSymbol": {
          "anyOf": [
            {
              "maxLength": 32,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Benchmarksymbol"
        },
        "cadenceMode": {
          "const": "strategy_native",
          "default": "strategy_native",
          "title": "Cadencemode",
          "type": "string"
        },
        "createdAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Createdat"
        },
        "createdBy": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Createdby"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "inceptionDate": {
          "format": "date",
          "title": "Inceptiondate",
          "type": "string"
        },
        "mandate": {
          "default": "",
          "title": "Mandate",
          "type": "string"
        },
        "mode": {
          "const": "internal_model_managed",
          "default": "internal_model_managed",
          "title": "Mode",
          "type": "string"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "status": {
          "default": "draft",
          "enum": [
            "draft",
            "active",
            "archived"
          ],
          "title": "Status",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
