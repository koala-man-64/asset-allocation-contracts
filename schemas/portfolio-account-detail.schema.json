      "required": [
        "accountId",
        "version",
        "name",
        "inceptionDate"
      ],
      "title": "PortfolioAccountRevision",
      "type": "object"
    },
    "PortfolioAssignment": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Accountid",
          "type": "string"
        },
        "accountVersion": {
          "minimum": 1,
          "title": "Accountversion",
          "type": "integer"
        },
        "assignmentId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Assignmentid",
          "type": "string"
        },
        "createdAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Createdat"
        },
        "effectiveFrom": {
          "format": "date",
          "title": "Effectivefrom",
          "type": "string"
        },
        "effectiveTo": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effectiveto"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "portfolioName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Portfolioname",
          "type": "string"
        },
        "portfolioVersion": {
          "minimum": 1,
          "title": "Portfolioversion",
          "type": "integer"
        },
        "status": {
          "default": "scheduled",
          "enum": [
            "scheduled",
            "active",
            "ended"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "assignmentId",
        "accountId",
        "accountVersion",
        "portfolioName",
        "portfolioVersion",
        "effectiveFrom"
      ],
      "title": "PortfolioAssignment",
      "type": "object"
    },
    "PortfolioLedgerEvent": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Accountid",
          "type": "string"
        },
        "cashAmount": {
          "title": "Cashamount",
          "type": "number"
        },
        "commission": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Commission",
          "type": "number"
        },
        "currency": {
          "default": "USD",
          "maxLength": 3,
          "minLength": 3,
          "title": "Currency",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "effectiveAt": {
          "format": "date-time",
          "title": "Effectiveat",
          "type": "string"
        },
        "eventId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Eventid",
          "type": "string"
        },
        "eventType": {
          "enum": [
            "opening_balance",
            "deposit",
            "withdrawal",
            "fee",
            "dividend",
            "rebalance_buy",
            "rebalance_sell",
            "correction"
          ],
          "title": "Eventtype",
          "type": "string"
        },
        "price": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Price"
        },
        "quantity": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quantity"
        },
        "slippageCost": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Slippagecost",
          "type": "number"
        },
        "symbol": {
          "anyOf": [
            {
              "maxLength": 32,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Symbol"
        }
      },
      "required": [
        "effectiveAt",
        "eventType",
        "cashAmount",
        "eventId",
        "accountId"
      ],
      "title": "PortfolioLedgerEvent",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "account": {
      "$ref": "#/$defs/PortfolioAccount"
    },
    "activeAssignment": {
      "anyOf": [
        {
          "$ref": "#/$defs/PortfolioAssignment"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "recentLedgerEvents": {
      "items": {
        "$ref": "#/$defs/PortfolioLedgerEvent"
      },
      "title": "Recentledgerevents",
      "type": "array"
    },
    "revision": {
      "anyOf": [
        {
          "$ref": "#/$defs/PortfolioAccountRevision"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "account"
  ],
  "title": "PortfolioAccountDetailResponse",
  "type": "object"
}
