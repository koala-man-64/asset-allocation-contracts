        "rvol_10d_ann": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rvol 10D Ann"
        },
        "spy_return_20d": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spy Return 20D"
        },
        "trend_state": {
          "anyOf": [
            {
              "enum": [
                "positive",
                "negative",
                "near_zero"
