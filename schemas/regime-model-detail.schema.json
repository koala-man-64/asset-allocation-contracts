        },
        "model_name": {
          "title": "Model Name",
          "type": "string"
        },
        "model_version": {
          "title": "Model Version",
          "type": "integer"
        },
        "regime_code": {
          "enum": [
            "trending_bull",
            "trending_bear",
            "choppy_mean_reversion",
            "high_vol",
            "unclassified"
