{
  "$defs": {
    "RegimeModelConfig": {
      "additionalProperties": false,
      "properties": {
        "bearVolMaxExclusive": {
          "default": 25.0,
          "title": "Bearvolmaxexclusive",
          "type": "number"
        },
        "bearVolMin": {
          "default": 15.0,
          "title": "Bearvolmin",
          "type": "number"
        },
        "bullVolMaxExclusive": {
          "default": 15.0,
          "title": "Bullvolmaxexclusive",
          "type": "number"
        },
        "choppyVolMaxExclusive": {
          "default": 18.0,
          "title": "Choppyvolmaxexclusive",
          "type": "number"
        },
        "choppyVolMin": {
          "default": 10.0,
          "title": "Choppyvolmin",
          "type": "number"
        },
        "curveContangoThreshold": {
          "default": 0.5,
          "title": "Curvecontangothreshold",
          "type": "number"
        },
        "curveInvertedThreshold": {
          "default": -0.5,
          "title": "Curveinvertedthreshold",
          "type": "number"
        },
        "haltVixStreakDays": {
          "default": 2,
          "minimum": 1,
          "title": "Haltvixstreakdays",
          "type": "integer"
        },
        "haltVixThreshold": {
          "default": 32.0,
          "title": "Haltvixthreshold",
          "type": "number"
        },
        "highVolEnterThreshold": {
          "default": 28.0,
          "title": "Highvolenterthreshold",
          "type": "number"
        },
        "highVolExitThreshold": {
          "default": 25.0,
          "title": "Highvolexitthreshold",
          "type": "number"
        },
        "precedence": {
          "items": {
            "enum": [
              "trending_bull",
              "trending_bear",
              "choppy_mean_reversion",
              "high_vol",
              "unclassified"
            ],
            "type": "string"
          },
          "title": "Precedence",
          "type": "array"
        },
        "trendNegativeThreshold": {
          "default": -0.02,
          "title": "Trendnegativethreshold",
          "type": "number"
        },
        "trendPositiveThreshold": {
          "default": 0.02,
          "title": "Trendpositivethreshold",
          "type": "number"
        }
      },
      "title": "RegimeModelConfig",
      "type": "object"
    },
    "RegimeModelRevision": {
      "additionalProperties": false,
      "properties": {
        "activated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated At"
        },
        "activated_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated By"
        },
        "config": {
          "$ref": "#/$defs/RegimeModelConfig"
        },
        "config_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Hash"
        },
        "created_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "published_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Published At"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        },
        "version": {
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "version",
        "config"
      ],
      "title": "RegimeModelRevision",
      "type": "object"
    },
    "RegimeModelSummary": {
      "additionalProperties": false,
      "properties": {
        "activated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated At"
        },
        "activated_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated By"
        },
        "active_version": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Active Version"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        },
        "version": {
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "RegimeModelSummary",
      "type": "object"
    },
    "RegimeSnapshot": {
      "additionalProperties": false,
      "properties": {
        "as_of_date": {
          "format": "date",
          "title": "As Of Date",
          "type": "string"
        },
        "computed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Computed At"
        },
        "curve_state": {
          "anyOf": [
            {
              "enum": [
                "contango",
                "flat",
                "inverted"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Curve State"
        },
        "effective_from_date": {
          "format": "date",
          "title": "Effective From Date",
          "type": "string"
        },
        "halt_flag": {
          "title": "Halt Flag",
          "type": "boolean"
        },
        "halt_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Halt Reason"
        },
        "matched_rule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
