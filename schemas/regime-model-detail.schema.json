        },
        "vix_gt_32_streak": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vix Gt 32 Streak"
        },
        "vix_slope": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vix Slope"
        },
        "vix_spot_close": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vix Spot Close"
        }
      },
      "required": [
        "as_of_date",
        "effective_from_date",
        "model_name",
        "model_version",
        "regime_code",
        "regime_status",
        "halt_flag"
      ],
      "title": "RegimeSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "activeRevision": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegimeModelRevision"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegimeSnapshot"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "model": {
      "$ref": "#/$defs/RegimeModelSummary"
    },
    "revisions": {
      "items": {
        "$ref": "#/$defs/RegimeModelRevision"
      },
      "title": "Revisions",
      "type": "array"
    }
  },
  "required": [
    "model"
  ],
  "title": "RegimeModelDetailResponse",
  "type": "object"
}
