{
  "$defs": {
    "RegimeMetricRule": {
      "additionalProperties": false,
      "properties": {
        "comparison": {
          "enum": [
            "gte",
            "lte",
            "between",
            "bool_true"
          ],
          "title": "Comparison",
          "type": "string"
        },
        "description": {
          "default": "",
          "maxLength": 512,
          "title": "Description",
          "type": "string"
        },
        "lower": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower"
        },
        "metric": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "upper": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper"
        }
      },
      "required": [
        "metric",
        "comparison"
      ],
      "title": "RegimeMetricRule",
      "type": "object"
    },
    "RegimeModelConfig": {
      "additionalProperties": false,
      "properties": {
        "activationThreshold": {
          "default": 0.6,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Activationthreshold",
          "type": "number"
        },
        "haltVixStreakDays": {
          "default": 2,
          "minimum": 1,
          "title": "Haltvixstreakdays",
          "type": "integer"
        },
        "haltVixThreshold": {
          "default": 32.0,
          "title": "Haltvixthreshold",
          "type": "number"
        },
        "signalConfigs": {
          "additionalProperties": {
            "$ref": "#/$defs/RegimeSignalConfig"
          },
          "propertyNames": {
            "enum": [
              "trending_up",
              "trending_down",
              "mean_reverting",
              "low_volatility",
              "high_volatility",
              "liquidity_stress",
              "macro_alignment",
              "unclassified"
            ]
          },
          "title": "Signalconfigs",
          "type": "object"
        }
      },
      "title": "RegimeModelConfig",
      "type": "object"
    },
    "RegimeModelRevision": {
      "additionalProperties": false,
      "properties": {
        "activated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated At"
        },
        "activated_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated By"
        },
        "config": {
          "$ref": "#/$defs/RegimeModelConfig"
        },
        "config_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Hash"
        },
        "created_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "published_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Published At"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        },
        "version": {
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "version",
        "config"
      ],
      "title": "RegimeModelRevision",
      "type": "object"
    },
    "RegimeModelSummary": {
      "additionalProperties": false,
      "properties": {
        "activated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated At"
        },
        "activated_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Activated By"
        },
        "active_version": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Active Version"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        },
        "version": {
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "RegimeModelSummary",
      "type": "object"
    },
    "RegimeSignal": {
      "additionalProperties": false,
      "properties": {
        "activation_threshold": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Activation Threshold",
          "type": "number"
        },
        "display_name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "evidence": {
          "additionalProperties": true,
          "title": "Evidence",
          "type": "object"
        },
        "is_active": {
          "title": "Is Active",
          "type": "boolean"
        },
        "matched_rule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matched Rule Id"
        },
        "regime_code": {
          "enum": [
            "trending_up",
            "trending_down",
            "mean_reverting",
            "low_volatility",
            "high_volatility",
            "liquidity_stress",
            "macro_alignment",
            "unclassified"
          ],
          "title": "Regime Code",
          "type": "string"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "signal_state": {
          "enum": [
            "active",
            "inactive",
            "insufficient_data"
          ],
          "title": "Signal State",
          "type": "string"
        }
      },
      "required": [
        "regime_code",
        "display_name",
        "signal_state",
        "score",
        "activation_threshold",
        "is_active"
      ],
      "title": "RegimeSignal",
      "type": "object"
    },
    "RegimeSignalConfig": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Displayname",
          "type": "string"
        },
        "requiredMetrics": {
          "items": {
            "type": "string"
          },
          "title": "Requiredmetrics",
          "type": "array"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/RegimeMetricRule"
          },
          "title": "Rules",
          "type": "array"
        }
      },
      "required": [
        "displayName"
      ],
      "title": "RegimeSignalConfig",
      "type": "object"
    },
    "RegimeSnapshot": {
      "additionalProperties": false,
      "properties": {
        "active_regimes": {
          "items": {
            "enum": [
              "trending_up",
              "trending_down",
              "mean_reverting",
              "low_volatility",
              "high_volatility",
              "liquidity_stress",
              "macro_alignment",
              "unclassified"
            ],
            "type": "string"
          },
          "title": "Active Regimes",
          "type": "array"
        },
        "as_of_date": {
          "format": "date",
          "title": "As Of Date",
          "type": "string"
        },
        "computed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Computed At"
        },
        "effective_from_date": {
          "format": "date",
          "title": "Effective From Date",
          "type": "string"
        },
        "halt_flag": {
          "title": "Halt Flag",
          "type": "boolean"
        },
        "halt_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Halt Reason"
        },
        "model_name": {
          "title": "Model Name",
          "type": "string"
        },
        "model_version": {
          "title": "Model Version",
          "type": "integer"
        },
        "signals": {
          "items": {
            "$ref": "#/$defs/RegimeSignal"
          },
          "title": "Signals",
          "type": "array"
        }
      },
      "required": [
        "as_of_date",
        "effective_from_date",
        "model_name",
        "model_version",
        "halt_flag"
      ],
      "title": "RegimeSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "activeRevision": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegimeModelRevision"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegimeSnapshot"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "model": {
      "$ref": "#/$defs/RegimeModelSummary"
    },
    "revisions": {
      "items": {
        "$ref": "#/$defs/RegimeModelRevision"
      },
      "title": "Revisions",
      "type": "array"
    }
  },
  "required": [
    "model"
  ],
  "title": "RegimeModelDetailResponse",
  "type": "object"
}
