      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "exit_full",
          "default": "exit_full",
          "title": "Action",
          "type": "string"
        },
        "atrColumn": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Atrcolumn"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "minHoldBars": {
          "default": 0,
          "minimum": 0,
          "title": "Minholdbars",
          "type": "integer"
        },
        "priceField": {
          "anyOf": [
            {
              "enum": [
                "open",
                "high",
                "low",
                "close"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricefield"
        },
        "priority": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Priority"
        },
        "reference": {
          "anyOf": [
            {
              "enum": [
                "entry_price",
                "highest_since_entry"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference"
        },
        "scope": {
          "const": "position",
          "default": "position",
          "title": "Scope",
          "type": "string"
        },
        "type": {
          "enum": [
            "stop_loss_fixed",
            "take_profit_fixed",
            "trailing_stop_pct",
            "trailing_stop_atr",
            "time_stop"
          ],
          "title": "Type",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "id",
        "type"
      ],
      "title": "ExitRule",
      "type": "object"
    },
    "RebalancePolicy": {
