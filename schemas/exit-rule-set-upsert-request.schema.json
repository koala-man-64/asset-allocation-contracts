{
  "$defs": {
    "ExitRule": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "exit_full",
          "default": "exit_full",
          "title": "Action",
          "type": "string"
        },
        "atrColumn": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Atrcolumn"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "minHoldBars": {
          "default": 0,
          "minimum": 0,
          "title": "Minholdbars",
          "type": "integer"
        },
        "priceField": {
          "anyOf": [
            {
              "enum": [
                "open",
                "high",
                "low",
                "close"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricefield"
        },
        "priority": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Priority"
        },
        "reference": {
          "anyOf": [
            {
              "enum": [
                "entry_price",
                "highest_since_entry"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference"
        },
        "scope": {
          "const": "position",
          "default": "position",
          "title": "Scope",
          "type": "string"
        },
        "type": {
          "enum": [
            "stop_loss_fixed",
            "take_profit_fixed",
            "trailing_stop_pct",
            "trailing_stop_atr",
            "time_stop"
          ],
          "title": "Type",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "id",
        "type"
      ],
      "title": "ExitRule",
      "type": "object"
    },
    "ExitRuleSetConfig": {
      "additionalProperties": false,
      "properties": {
        "exits": {
          "items": {
            "$ref": "#/$defs/ExitRule"
          },
          "title": "Exits",
          "type": "array"
        },
        "intrabarConflictPolicy": {
          "default": "stop_first",
          "enum": [
            "stop_first",
            "take_profit_first",
            "priority_order"
          ],
          "title": "Intrabarconflictpolicy",
          "type": "string"
        }
      },
      "title": "ExitRuleSetConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "config": {
      "$ref": "#/$defs/ExitRuleSetConfig"
    },
    "description": {
      "default": "",
      "maxLength": 2048,
      "title": "Description",
      "type": "string"
    },
    "name": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    }
  },
  "required": [
    "name",
    "config"
  ],
  "title": "ExitRuleSetUpsertRequest",
  "type": "object"
}
