{
  "$defs": {
    "RegimeSignal": {
      "additionalProperties": false,
      "properties": {
        "activation_threshold": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Activation Threshold",
          "type": "number"
        },
        "display_name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "evidence": {
          "additionalProperties": true,
          "title": "Evidence",
          "type": "object"
        },
        "is_active": {
          "title": "Is Active",
          "type": "boolean"
        },
        "matched_rule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matched Rule Id"
        },
        "regime_code": {
          "enum": [
            "trending_up",
            "trending_down",
            "mean_reverting",
            "low_volatility",
            "high_volatility",
            "liquidity_stress",
            "macro_alignment",
            "unclassified"
          ],
          "title": "Regime Code",
          "type": "string"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "signal_state": {
          "enum": [
            "active",
            "inactive",
            "insufficient_data"
          ],
          "title": "Signal State",
          "type": "string"
        }
      },
      "required": [
        "regime_code",
        "display_name",
        "signal_state",
        "score",
        "activation_threshold",
        "is_active"
      ],
      "title": "RegimeSignal",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "active_regimes": {
      "items": {
        "enum": [
          "trending_up",
          "trending_down",
          "mean_reverting",
          "low_volatility",
          "high_volatility",
          "liquidity_stress",
          "macro_alignment",
          "unclassified"
        ],
        "type": "string"
      },
      "title": "Active Regimes",
      "type": "array"
    },
    "as_of_date": {
      "format": "date",
      "title": "As Of Date",
      "type": "string"
    },
    "computed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Computed At"
    },
    "effective_from_date": {
      "format": "date",
      "title": "Effective From Date",
      "type": "string"
    },
    "halt_flag": {
      "title": "Halt Flag",
      "type": "boolean"
    },
    "halt_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Halt Reason"
    },
    "model_name": {
      "title": "Model Name",
      "type": "string"
    },
    "model_version": {
      "title": "Model Version",
      "type": "integer"
    },
    "signals": {
      "items": {
        "$ref": "#/$defs/RegimeSignal"
      },
      "title": "Signals",
      "type": "array"
    }
  },
  "required": [
    "as_of_date",
    "effective_from_date",
    "model_name",
    "model_version",
    "halt_flag"
  ],
  "title": "RegimeSnapshot",
  "type": "object"
}
