        "staleReason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stalereason"
        }
      },
      "title": "TradeDataFreshness",
      "type": "object"
    },
    "TradePosition": {
