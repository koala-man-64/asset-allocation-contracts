      "$ref": "#/$defs/TradeDataFreshness"
    },
    "generatedAt": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generatedat"
    },
    "positions": {
      "items": {
        "$ref": "#/$defs/TradePosition"
      },
      "title": "Positions",
      "type": "array"
    }
