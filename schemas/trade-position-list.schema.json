            "fresh",
            "stale",
            "unknown"
          ],
          "title": "Balancesstate",
          "type": "string"
        },
        "maxAgeSeconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maxageseconds"
        },
        "ordersAsOf": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ordersasof"
        },
        "ordersState": {
          "default": "unknown",
          "enum": [
            "fresh",
            "stale",
            "unknown"
          ],
          "title": "Ordersstate",
          "type": "string"
        },
        "positionsAsOf": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Positionsasof"
        },
        "positionsState": {
          "default": "unknown",
