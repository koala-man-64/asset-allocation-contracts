{
  "$defs": {
    "RegimeMetricRule": {
      "additionalProperties": false,
      "properties": {
        "comparison": {
          "enum": [
            "gte",
            "lte",
            "between",
            "bool_true"
          ],
          "title": "Comparison",
          "type": "string"
        },
        "description": {
          "default": "",
          "maxLength": 512,
          "title": "Description",
          "type": "string"
        },
        "lower": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower"
        },
        "metric": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "upper": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper"
        }
      },
      "required": [
        "metric",
        "comparison"
      ],
      "title": "RegimeMetricRule",
      "type": "object"
    },
    "RegimeSignalConfig": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Displayname",
          "type": "string"
        },
        "requiredMetrics": {
          "items": {
            "type": "string"
          },
          "title": "Requiredmetrics",
          "type": "array"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/RegimeMetricRule"
          },
          "title": "Rules",
          "type": "array"
        }
      },
      "required": [
        "displayName"
      ],
      "title": "RegimeSignalConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "activationThreshold": {
      "default": 0.6,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Activationthreshold",
      "type": "number"
    },
    "haltVixStreakDays": {
      "default": 2,
      "minimum": 1,
      "title": "Haltvixstreakdays",
      "type": "integer"
    },
    "haltVixThreshold": {
      "default": 32.0,
      "title": "Haltvixthreshold",
      "type": "number"
    },
    "signalConfigs": {
      "additionalProperties": {
        "$ref": "#/$defs/RegimeSignalConfig"
      },
      "propertyNames": {
        "enum": [
          "trending_up",
          "trending_down",
          "mean_reverting",
          "low_volatility",
          "high_volatility",
          "liquidity_stress",
          "macro_alignment",
          "unclassified"
        ]
      },
      "title": "Signalconfigs",
      "type": "object"
    }
  },
  "title": "RegimeModelConfig",
  "type": "object"
}
