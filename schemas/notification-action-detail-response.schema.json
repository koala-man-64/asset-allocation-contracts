{
  "$defs": {
    "TradeApprovalDisplay": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Accountid",
          "type": "string"
        },
        "environment": {
          "enum": [
            "paper",
            "sandbox",
            "live"
          ],
          "title": "Environment",
          "type": "string"
        },
        "limitPrice": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Limitprice"
        },
        "notional": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notional"
        },
        "orderHash": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Orderhash",
          "type": "string"
        },
        "orderType": {
          "enum": [
            "market",
            "limit",
            "stop",
            "stop_limit"
          ],
          "title": "Ordertype",
          "type": "string"
        },
        "previewId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Previewid",
          "type": "string"
        },
        "quantity": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quantity"
        },
        "side": {
          "enum": [
            "buy",
            "sell"
          ],
          "title": "Side",
          "type": "string"
        },
        "stopPrice": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stopprice"
        },
        "symbol": {
          "maxLength": 32,
          "minLength": 1,
          "title": "Symbol",
          "type": "string"
        },
        "timeInForce": {
          "default": "day",
          "enum": [
            "day",
            "gtc",
            "opg",
            "cls",
            "ioc",
            "fok"
          ],
          "title": "Timeinforce",
          "type": "string"
        }
      },
      "required": [
        "accountId",
        "previewId",
        "orderHash",
        "environment",
        "symbol",
        "side",
        "orderType"
      ],
      "title": "TradeApprovalDisplay",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "createdAt": {
      "format": "date-time",
      "title": "Createdat",
      "type": "string"
    },
    "decisionStatus": {
      "default": "not_required",
      "enum": [
        "not_required",
        "pending",
        "approved",
        "denied",
        "expired"
      ],
      "title": "Decisionstatus",
      "type": "string"
    },
    "description": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "executionStatus": {
      "default": "not_applicable",
      "enum": [
        "not_applicable",
        "pending_approval",
        "submitted",
        "blocked",
        "release_failed"
      ],
      "title": "Executionstatus",
      "type": "string"
    },
    "expiresAt": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expiresat"
    },
    "kind": {
      "enum": [
        "message",
        "trade_approval"
      ],
      "title": "Kind",
      "type": "string"
    },
    "requestId": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Requestid",
      "type": "string"
    },
    "targetUrl": {
      "anyOf": [
        {
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Targeturl"
    },
    "title": {
      "maxLength": 160,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "tokenId": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Tokenid",
      "type": "string"
    },
    "tradeApproval": {
      "anyOf": [
        {
          "$ref": "#/$defs/TradeApprovalDisplay"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "requestId",
    "tokenId",
    "kind",
    "title",
    "description",
    "createdAt"
  ],
  "title": "NotificationActionDetailResponse",
  "type": "object"
}
