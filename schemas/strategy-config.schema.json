{
  "$defs": {
    "ExitRule": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "exit_full",
          "default": "exit_full",
          "title": "Action",
          "type": "string"
        },
        "atrColumn": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Atrcolumn"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "minHoldBars": {
          "default": 0,
          "minimum": 0,
          "title": "Minholdbars",
          "type": "integer"
        },
        "priceField": {
          "anyOf": [
            {
              "enum": [
                "open",
                "high",
                "low",
                "close"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricefield"
        },
        "priority": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Priority"
        },
        "reference": {
          "anyOf": [
            {
              "enum": [
                "entry_price",
                "highest_since_entry"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference"
        },
        "scope": {
          "const": "position",
          "default": "position",
          "title": "Scope",
          "type": "string"
        },
        "type": {
          "enum": [
            "stop_loss_fixed",
            "take_profit_fixed",
            "trailing_stop_pct",
            "trailing_stop_atr",
            "time_stop"
          ],
          "title": "Type",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "id",
        "type"
      ],
      "title": "ExitRule",
      "type": "object"
    },
    "RegimePolicy": {
      "additionalProperties": false,
      "properties": {
        "blockOnTransition": {
          "default": true,
          "title": "Blockontransition",
          "type": "boolean"
        },
        "blockOnUnclassified": {
          "default": true,
          "title": "Blockonunclassified",
          "type": "boolean"
        },
        "honorHaltFlag": {
          "default": true,
          "title": "Honorhaltflag",
          "type": "boolean"
        },
        "modelName": {
          "default": "default-regime",
          "maxLength": 128,
          "minLength": 1,
          "title": "Modelname",
          "type": "string"
        },
        "onBlocked": {
          "default": "skip_entries",
          "enum": [
            "skip_entries",
            "skip_rebalance"
          ],
          "title": "Onblocked",
          "type": "string"
        },
        "targetGrossExposureByRegime": {
          "$ref": "#/$defs/TargetGrossExposureByRegime"
        }
      },
      "title": "RegimePolicy",
      "type": "object"
    },
    "TargetGrossExposureByRegime": {
      "additionalProperties": false,
      "properties": {
        "choppy_mean_reversion": {
          "default": 0.75,
          "minimum": 0.0,
          "title": "Choppy Mean Reversion",
          "type": "number"
        },
        "high_vol": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "High Vol",
          "type": "number"
        },
        "trending_bear": {
          "default": 0.5,
          "minimum": 0.0,
          "title": "Trending Bear",
          "type": "number"
        },
        "trending_bull": {
          "default": 1.0,
          "minimum": 0.0,
          "title": "Trending Bull",
          "type": "number"
        },
        "unclassified": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Unclassified",
          "type": "number"
        }
      },
      "title": "TargetGrossExposureByRegime",
      "type": "object"
    },
    "UniverseCondition": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Column",
          "type": "string"
        },
        "kind": {
          "const": "condition",
          "default": "condition",
          "title": "Kind",
          "type": "string"
        },
        "operator": {
          "enum": [
            "eq",
            "ne",
            "gt",
            "gte",
            "lt",
            "lte",
            "in",
            "not_in",
            "is_null",
            "is_not_null"
          ],
          "title": "Operator",
          "type": "string"
        },
        "table": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Table",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "values": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Values"
        }
      },
      "required": [
        "table",
        "column",
        "operator"
      ],
      "title": "UniverseCondition",
      "type": "object"
    },
    "UniverseDefinition": {
      "additionalProperties": false,
      "properties": {
        "root": {
          "$ref": "#/$defs/UniverseGroup"
        },
        "source": {
          "const": "postgres_gold",
          "default": "postgres_gold",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "root"
      ],
      "title": "UniverseDefinition",
      "type": "object"
    },
    "UniverseGroup": {
      "additionalProperties": false,
      "properties": {
        "clauses": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/UniverseGroup"
              },
              {
                "$ref": "#/$defs/UniverseCondition"
              }
            ]
          },
          "minItems": 1,
          "title": "Clauses",
          "type": "array"
        },
        "kind": {
          "const": "group",
          "default": "group",
          "title": "Kind",
          "type": "string"
        },
        "operator": {
          "default": "and",
          "enum": [
            "and",
            "or"
          ],
          "title": "Operator",
          "type": "string"
        }
      },
      "required": [
        "clauses"
      ],
      "title": "UniverseGroup",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "costModel": {
      "default": "default",
      "maxLength": 64,
      "minLength": 1,
      "title": "Costmodel",
      "type": "string"
    },
    "exits": {
      "items": {
        "$ref": "#/$defs/ExitRule"
      },
      "title": "Exits",
      "type": "array"
    },
    "holdingPeriod": {
      "default": 21,
      "minimum": 1,
      "title": "Holdingperiod",
      "type": "integer"
    },
    "intrabarConflictPolicy": {
      "default": "stop_first",
      "enum": [
        "stop_first",
        "take_profit_first",
        "priority_order"
      ],
      "title": "Intrabarconflictpolicy",
      "type": "string"
    },
    "longOnly": {
      "default": true,
      "title": "Longonly",
      "type": "boolean"
    },
    "lookbackWindow": {
      "default": 63,
      "minimum": 1,
      "title": "Lookbackwindow",
      "type": "integer"
    },
    "rankingSchemaName": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rankingschemaname"
    },
    "rebalance": {
      "default": "monthly",
      "maxLength": 64,
      "minLength": 1,
      "title": "Rebalance",
      "type": "string"
    },
    "regimePolicy": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegimePolicy"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "topN": {
      "default": 20,
      "minimum": 1,
      "title": "Topn",
      "type": "integer"
    },
    "universe": {
      "anyOf": [
        {
          "$ref": "#/$defs/UniverseDefinition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "universeConfigName": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Universeconfigname"
    }
  },
  "title": "StrategyConfig",
  "type": "object"
}
