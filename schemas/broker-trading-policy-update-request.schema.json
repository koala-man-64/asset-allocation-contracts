{
  "$defs": {
    "BrokerPositionSizeLimit": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "default": "pct_of_allocatable_capital",
          "enum": [
            "pct_of_allocatable_capital",
            "notional_base_ccy"
          ],
          "title": "Mode",
          "type": "string"
        },
        "value": {
          "exclusiveMinimum": 0.0,
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "value"
      ],
      "title": "BrokerPositionSizeLimit",
      "type": "object"
    },
    "BrokerTradingPolicy": {
      "additionalProperties": false,
      "properties": {
        "allowedAssetClasses": {
          "items": {
            "enum": [
              "equity",
              "option"
            ],
            "type": "string"
          },
          "title": "Allowedassetclasses",
          "type": "array"
        },
        "allowedSides": {
          "items": {
            "enum": [
              "long",
              "short"
            ],
            "type": "string"
          },
          "title": "Allowedsides",
          "type": "array"
        },
        "maxOpenPositions": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maxopenpositions"
        },
        "maxSinglePositionExposure": {
          "anyOf": [
            {
              "$ref": "#/$defs/BrokerPositionSizeLimit"
            },
            {
              "type": "null"
            }
          ],
          "default": null
