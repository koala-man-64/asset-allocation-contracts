        "requireOrderConfirmation": {
          "default": false,
          "title": "Requireorderconfirmation",
          "type": "boolean"
        }
      },
      "title": "BrokerTradingPolicy",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "expectedConfigurationVersion": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expectedconfigurationversion"
    },
    "requestedPolicy": {
      "$ref": "#/$defs/BrokerTradingPolicy"
    }
  },
  "required": [
    "requestedPolicy"
