{
  "$defs": {
    "StrategyAnalyticsReference": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "role": {
          "default": "candidate",
          "enum": [
            "baseline",
            "challenger",
            "candidate"
          ],
          "title": "Role",
          "type": "string"
        },
        "runId": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runid"
        },
        "strategyName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Strategyname",
          "type": "string"
        },
        "strategyVersion": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strategyversion"
        }
      },
      "required": [
        "strategyName"
      ],
      "title": "StrategyAnalyticsReference",
      "type": "object"
    },
    "StrategyComparisonMetricRow": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "metric": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "unit": {
          "enum": [
            "ratio",
            "currency",
            "count",
            "bps",
            "days",
            "score"
          ],
          "title": "Unit",
          "type": "string"
        },
        "values": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Values",
          "type": "object"
        },
        "winnerStrategyName": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Winnerstrategyname"
        }
      },
      "required": [
        "metric",
        "label",
        "unit"
      ],
      "title": "StrategyComparisonMetricRow",
      "type": "object"
    },
    "StrategyComparisonRunEvidence": {
      "additionalProperties": false,
      "properties": {
        "barSize": {
          "maxLength": 32,
          "minLength": 1,
          "title": "Barsize",
          "type": "string"
        },
        "costModel": {
          "default": "default",
          "maxLength": 64,
          "minLength": 1,
          "title": "Costmodel",
          "type": "string"
        },
        "endDate": {
          "format": "date",
          "title": "Enddate",
          "type": "string"
        },
        "resultSchemaVersion": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resultschemaversion"
        },
        "runId": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runid"
        },
        "startDate": {
          "format": "date",
          "title": "Startdate",
          "type": "string"
        },
        "strategyName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Strategyname",
          "type": "string"
        },
        "strategyVersion": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strategyversion"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "strategyName",
        "startDate",
        "endDate",
        "barSize"
      ],
      "title": "StrategyComparisonRunEvidence",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "asOf": {
      "format": "date-time",
      "title": "Asof",
      "type": "string"
    },
    "barSize": {
      "maxLength": 32,
      "minLength": 1,
      "title": "Barsize",
      "type": "string"
    },
    "benchmarkSymbol": {
      "anyOf": [
        {
          "maxLength": 32,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Benchmarksymbol"
    },
    "blockedReasons": {
      "items": {
        "type": "string"
      },
      "title": "Blockedreasons",
      "type": "array"
    },
    "costModel": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Costmodel",
      "type": "string"
    },
    "metrics": {
      "items": {
        "$ref": "#/$defs/StrategyComparisonMetricRow"
      },
      "title": "Metrics",
      "type": "array"
    },
    "runEvidence": {
      "items": {
        "$ref": "#/$defs/StrategyComparisonRunEvidence"
      },
      "title": "Runevidence",
      "type": "array"
    },
    "strategies": {
      "items": {
        "$ref": "#/$defs/StrategyAnalyticsReference"
      },
      "minItems": 2,
      "title": "Strategies",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "asOf",
    "costModel",
    "barSize",
    "strategies"
  ],
  "title": "StrategyComparisonResponse",
  "type": "object"
}
