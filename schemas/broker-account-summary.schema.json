          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authexpiresat"
        },
        "authStatus": {
          "default": "not_connected",
          "enum": [
            "authenticated",
            "expires_soon",
            "expired",
            "reauth_required",
            "not_connected"
          ],
          "title": "Authstatus",
          "type": "string"
        },
        "connectionState": {
          "default": "disconnected",
          "enum": [
            "connected",
            "degraded",
            "disconnected",
            "reconnect_required"
          ],
