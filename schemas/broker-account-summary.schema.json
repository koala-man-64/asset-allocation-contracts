{
  "$defs": {
    "BrokerConnectionHealth": {
      "additionalProperties": false,
      "properties": {
        "authExpiresAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authexpiresat"
        },
        "authStatus": {
          "default": "not_connected",
          "enum": [
            "authenticated",
            "expires_soon",
            "expired",
            "reauth_required",
            "not_connected"
          ],
          "title": "Authstatus",
          "type": "string"
        },
        "connectionState": {
          "default": "disconnected",
          "enum": [
            "connected",
            "degraded",
            "disconnected",
            "reconnect_required"
          ],
          "title": "Connectionstate",
          "type": "string"
        },
        "failureMessage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failuremessage"
        },
        "lastCheckedAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lastcheckedat"
        },
        "lastFailedSyncAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lastfailedsyncat"
        },
        "lastSuccessfulSyncAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lastsuccessfulsyncat"
        },
        "overallStatus": {
          "default": "warning",
          "enum": [
            "healthy",
            "warning",
            "critical"
          ],
          "title": "Overallstatus",
          "type": "string"
        },
        "staleReason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stalereason"
        },
        "syncPaused": {
          "default": false,
          "title": "Syncpaused",
          "type": "boolean"
        },
        "syncStatus": {
          "default": "never_synced",
          "enum": [
            "fresh",
            "stale",
            "syncing",
            "paused",
            "failed",
            "never_synced"
          ],
          "title": "Syncstatus",
          "type": "string"
        }
      },
      "title": "BrokerConnectionHealth",
      "type": "object"
    },
    "BrokerStrategyAllocationItem": {
      "additionalProperties": false,
      "properties": {
        "allocationMode": {
          "default": "percent",
          "enum": [
            "percent",
            "notional_base_ccy"
          ],
          "title": "Allocationmode",
          "type": "string"
        },
        "derivedWeightPct": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivedweightpct"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "sleeveId": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Sleeveid",
          "type": "string"
        },
        "sleeveName": {
          "default": "",
          "title": "Sleevename",
          "type": "string"
        },
        "strategy": {
          "$ref": "#/$defs/BrokerStrategyReference"
        },
        "targetNotionalBaseCcy": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Targetnotionalbaseccy"
        },
        "targetWeightPct": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Targetweightpct"
        }
      },
      "required": [
        "sleeveId",
        "strategy"
      ],
      "title": "BrokerStrategyAllocationItem",
      "type": "object"
    },
    "BrokerStrategyAllocationSummary": {
      "additionalProperties": false,
      "properties": {
        "allocatableCapital": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allocatablecapital"
        },
        "allocatedNotionalBaseCcy": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allocatednotionalbaseccy"
        },
        "allocatedPercent": {
          "anyOf": [
            {
              "maximum": 100.01,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allocatedpercent"
        },
        "allocationMode": {
          "default": "percent",
          "enum": [
            "percent",
            "notional_base_ccy"
          ],
          "title": "Allocationmode",
          "type": "string"
        },
        "effectiveFrom": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effectivefrom"
        },
        "items": {
          "items": {
            "$ref": "#/$defs/BrokerStrategyAllocationItem"
          },
          "title": "Items",
          "type": "array"
        },
        "portfolioName": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Portfolioname"
        },
        "portfolioVersion": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Portfolioversion"
        },
        "remainingNotionalBaseCcy": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remainingnotionalbaseccy"
        },
        "remainingPercent": {
          "anyOf": [
            {
              "maximum": 100.01,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remainingpercent"
        },
        "sharedActivePortfolio": {
          "default": false,
          "title": "Sharedactiveportfolio",
          "type": "boolean"
        }
      },
      "title": "BrokerStrategyAllocationSummary",
      "type": "object"
    },
    "BrokerStrategyReference": {
      "additionalProperties": false,
      "properties": {
        "strategyName": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Strategyname",
          "type": "string"
        },
        "strategyVersion": {
          "minimum": 1,
          "title": "Strategyversion",
          "type": "integer"
        }
      },
      "required": [
        "strategyName",
        "strategyVersion"
      ],
      "title": "BrokerStrategyReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "accountId": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Accountid",
      "type": "string"
    },
    "accountNumberMasked": {
      "anyOf": [
        {
          "maxLength": 32,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Accountnumbermasked"
    },
    "activePortfolioName": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Activeportfolioname"
    },
    "alertCount": {
      "default": 0,
      "minimum": 0,
      "title": "Alertcount",
      "type": "integer"
    },
    "allocationSummary": {
      "anyOf": [
        {
          "$ref": "#/$defs/BrokerStrategyAllocationSummary"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "baseCurrency": {
      "default": "USD",
      "maxLength": 3,
      "minLength": 3,
      "title": "Basecurrency",
      "type": "string"
    },
    "broker": {
      "enum": [
        "alpaca",
        "schwab",
        "etrade",
        "kalshi"
      ],
      "title": "Broker",
      "type": "string"
    },
    "buyingPower": {
      "default": 0.0,
      "title": "Buyingpower",
      "type": "number"
    },
    "cash": {
      "default": 0.0,
      "title": "Cash",
      "type": "number"
    },
    "configurationVersion": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Configurationversion"
    },
    "connectionHealth": {
      "$ref": "#/$defs/BrokerConnectionHealth"
    },
    "equity": {
      "default": 0.0,
      "title": "Equity",
      "type": "number"
    },
    "highestAlertSeverity": {
      "anyOf": [
        {
          "enum": [
            "info",
            "warning",
            "critical"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Highestalertseverity"
    },
    "lastSyncedAt": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lastsyncedat"
    },
    "name": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "openOrderCount": {
      "default": 0,
      "minimum": 0,
      "title": "Openordercount",
      "type": "integer"
    },
    "openPositionCount": {
      "default": 0,
      "minimum": 0,
      "title": "Openpositioncount",
      "type": "integer"
    },
    "overallStatus": {
      "default": "warning",
      "enum": [
        "healthy",
        "warning",
        "critical"
      ],
      "title": "Overallstatus",
      "type": "string"
    },
    "snapshotAsOf": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Snapshotasof"
    },
    "strategyLabel": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Strategylabel"
    },
    "tradeReadiness": {
      "default": "review",
      "enum": [
        "ready",
        "review",
        "blocked"
      ],
      "title": "Tradereadiness",
      "type": "string"
    },
    "tradeReadinessReason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tradereadinessreason"
    }
  },
  "required": [
    "accountId",
    "broker",
    "name"
  ],
  "title": "BrokerAccountSummary",
  "type": "object"
}
