    "openPositionCount": {
      "default": 0,
      "minimum": 0,
      "title": "Openpositioncount",
      "type": "integer"
    },
    "overallStatus": {
      "default": "warning",
      "enum": [
        "healthy",
        "warning",
        "critical"
