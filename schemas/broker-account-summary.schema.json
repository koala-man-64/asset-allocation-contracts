          "default": null,
          "title": "Lastfailedsyncat"
        },
        "lastSuccessfulSyncAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lastsuccessfulsyncat"
        },
        "overallStatus": {
          "default": "warning",
          "enum": [
            "healthy",
            "warning",
            "critical"
          ],
          "title": "Overallstatus",
          "type": "string"
        },
        "staleReason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stalereason"
        },
        "syncPaused": {
          "default": false,
